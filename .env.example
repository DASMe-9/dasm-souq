# ═══════════════════════════════════════════════════════════════
# DASM Souq — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env.local for local dev. Production values go in Vercel env.

# ─── Core Platform (DASM main backend on Render) ─────────────────
# Used by: UI links pointing back to dasm.com.sa, auth redirects,
# and read-only fetches for regions/categories (source of truth).
NEXT_PUBLIC_CORE_API_URL=https://api.dasm.com.sa/api
NEXT_PUBLIC_CORE_SITE_URL=https://www.dasm.com.sa

# ─── DASM Services DB (Supabase — marketplace listings/shipping/inspection) ───
# Project: bmfqfmsxtotdksvcqfrh
NEXT_PUBLIC_SUPABASE_URL=https://bmfqfmsxtotdksvcqfrh.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# SERVER-ONLY — never exposed to client. Set in Vercel as non-public env.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# ─── DASM Talk (for widget integration on listing cards) ─────────
NEXT_PUBLIC_TALK_URL=https://talk.dasm.com.sa

# ─── (Optional) Legacy JWT keys kept for rollback/debug only ─────
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_LEGACY_JWT=eyJ...
